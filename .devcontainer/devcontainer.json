{
  "forwardPorts": [3000, 3001],
  "portsAttributes": {
    "3000": {
      "label": "LifeMap UI",
      "protocol": "http",
      "onAutoForward": "silent",
      "visibility": "public"
    },
    "3001": {
      "label": "LifeMap API / Telegram webhook",
      "protocol": "http",
      "onAutoForward": "silent",
      "visibility": "public"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },
  "postStartCommand": "bash .devcontainer/set-public-ports.sh >/tmp/lifemap-public-ports-start.log 2>&1 || true"
}
