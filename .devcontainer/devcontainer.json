{
  "forwardPorts": [3000, 3001, 8080],
  "portsAttributes": {
    "3000": {
      "label": "LifeMap UI",
      "onAutoForward": "silent",
      "visibility": "public"
    },
    "3001": {
      "label": "LifeMap API / Telegram webhook",
      "onAutoForward": "silent",
      "visibility": "public"
    },
    "8080": {
      "label": "LifeMap UI alt",
      "onAutoForward": "silent",
      "visibility": "public"
    }
  },
  "postStartCommand": "bash .devcontainer/set-public-ports.sh || true",
  "postAttachCommand": "bash .devcontainer/set-public-ports.sh || true"
}
